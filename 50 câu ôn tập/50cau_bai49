import random

class UniversalHash:
    def __init__(self, m, p=10**9 + 7):
        self.p = p
        self.m = m
        self.a = random.randint(1, p - 1)
        self.b = random.randint(0, p - 1)
        
    def hash(self, k):
        return ((self.a * k + self.b) % self.p) % self.m

uh = UniversalHash(10)
print(uh.hash(42))
