def rotate(nums, k):
    k %= len(nums)
    def reverse(start, end):
        while start < end:
            nums[start], nums[end] = nums[end], nums[start]
            start, end = start + 1, end - 1
            
    reverse(0, len(nums) - 1)
    reverse(0, k - 1)
    reverse(k, len(nums) - 1)

arr_rot = [1, 2, 3, 4, 5, 6, 7]
rotate(arr_rot, 3)
print(arr_rot)