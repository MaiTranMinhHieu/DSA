import heapq
g1 = {0: [(1,4), (2,1)], 1: [(3,1)], 2: [(1,2), (3,5), (4,8)], 3: [(4,3), (5,6)], 4: [(5,2)], 5: []}
def bai_17(g, s, t):
    dist = {n: float('inf') for n in g}; dist[s] = 0
    pq = [(0, s)]
    while pq:
        d, u = heapq.heappop(pq)
        if u == t: print(f"Giá trị bottleneck (max cạnh nhỏ nhất): {d}"); return
        for v, w in g[u]:
            m = max(d, w)
            if m < dist[v]: dist[v] = m; heapq.heappush(pq, (m, v))
bai_17(g1, 0, 5)